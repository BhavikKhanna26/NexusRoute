# ─────────────────────────────────────────────────────────────────────────────
# NexusRoute — Environment Variables
#
# Copy this file to .env and fill in real values.
# .env is gitignored. NEVER commit real credentials.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB ───────────────────────────────────────────────────────────────────

# Logistics Atlas cluster — READ ONLY.
# Services use this to read: oms_shipments, tms_*, mst_* collections.
# No service writes to this URI.
LOGISTICS_MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net?retryWrites=true&w=majority
# Explicit DB name — kept separate so the DB is visible independent of the URI.
# The URI above intentionally omits the DB path — the driver uses this variable instead.
LOGISTICS_MONGODB_DB=logistics

# Your personal Atlas cluster — READ + WRITE.
# All new collections live here: shipment_sla_events, carrier_performance_metrics,
# pincode_delay_index, ml_predictions.
# Initialize once with: mongosh "$NEXUSROUTE_MONGODB_URI/$NEXUSROUTE_MONGODB_DB" --file mongo/init.js
NEXUSROUTE_MONGODB_URI=mongodb+srv://iambhavikkhanna02:mydatabase@cluster0.leqlldl.mongodb.net/
NEXUSROUTE_MONGODB_DB=nexusroute

# ── PostgreSQL (Docker) ───────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexusroute
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexuspass
# Assembled URI for services that prefer a single connection string
POSTGRES_URI=postgresql://nexus:nexuspass@localhost:5432/nexusroute

# ── Kafka (Docker) ────────────────────────────────────────────────────────────
# Use localhost:9092 from your host machine (outside Docker)
# Use kafka:29092 from inside Docker containers
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Redis (Docker) ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── ML Serving ────────────────────────────────────────────────────────────────
ML_SERVING_URL=http://localhost:8000
ML_SERVING_TIMEOUT_MS=200
ML_CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
ML_CIRCUIT_BREAKER_RECOVERY_SECONDS=30

# ── GraphQL Gateway ───────────────────────────────────────────────────────────
# Downstream service URLs (no trailing slash)
ORDER_SERVICE_URL=http://localhost:3001
ROUTING_SERVICE_URL=http://localhost:3002
ALERT_SERVICE_URL=http://localhost:3003

# Rate limiting (token bucket per seller, stored in Redis)
RATE_LIMIT_MAX_TOKENS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ── Auth ──────────────────────────────────────────────────────────────────────
# RS256 key pair — generate once:
#   mkdir keys
#   openssl genrsa -out keys/private.pem 2048
#   openssl rsa -in keys/private.pem -pubout -out keys/public.pem
# Gateway only needs the public key. Private key stays with the auth server.
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem

# ── Internal Service API Key ──────────────────────────────────────────────────
# Shared secret for service-to-service calls (X-Internal-API-Key header)
INTERNAL_API_KEY=replace-with-a-strong-random-string

# ── Tracking Ingestion ────────────────────────────────────────────────────────
# HMAC secret per carrier — used to validate incoming webhooks
CARRIER_HMAC_SECRET_DTDC=replace-with-carrier-provided-secret
CARRIER_HMAC_SECRET_BLUEDART=replace-with-carrier-provided-secret
CARRIER_HMAC_SECRET_DELHIVERY=replace-with-carrier-provided-secret
